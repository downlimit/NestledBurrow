{
  "name": "nestledburrow",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "npm run check:docs && npm run check:binary-import && npm run check:input && npm run check:runtime-components && npm run check:fullscreen && npm run check:hud && npm run check:movement && npm run check:character && npm run check:character-diagonals && npm run check:patrol && npm run check:interaction && npm run check:dialogue && npm run check:progress && npm run check:i18n && npm run check:visual && npm run check:world && npm run check:room-preview && npm run build",
    "check:docs": "node scripts/check-doc-contracts.mjs",
    "check:binary-import": "node scripts/check-binary-import.mjs",
    "check:input": "node scripts/check-input.mjs",
    "check:movement": "node scripts/check-movement.mjs",
    "check:visual": "node scripts/check-visual.mjs",
    "check:world": "node scripts/check-world.mjs",
    "check:room-preview": "python scripts/check-room-preview.py",
    "check:fullscreen": "node scripts/check-fullscreen.mjs",
    "check:hud": "node scripts/check-hud.mjs",
    "check:character": "node scripts/check-character.mjs",
    "check:character-diagonals": "python scripts/check-character-diagonals.py",
    "check:patrol": "node scripts/check-patrol-contract.mjs",
    "check:runtime-components": "node scripts/check-runtime-components.mjs",
    "check:interaction": "node scripts/check-interaction.mjs",
    "check:dialogue": "node scripts/check-dialogue.mjs",
    "i18n:status": "i18next-cli status",
    "i18n:lint": "i18next-cli lint",
    "check:i18n": "node scripts/check-localization.mjs && npm run i18n:status && npm run i18n:lint",
    "check:progress": "node scripts/check-progress.mjs",
    "check:e2e": "playwright test"
  },
  "dependencies": {
    "phaser": "4.2.1",
    "i18next": "^25.3.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "i18next-icu": "^2.4.1"
  },
  "devDependencies": {
    "vite": "8.1.5",
    "i18next-cli": "^1.5.0",
    "@playwright/test": "1.54.2"
  }
}
